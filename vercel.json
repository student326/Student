{
  "services": {
    "frontend": {
      "root": "frontend/",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "installCommand": "npm install",
      "rewrites": [
        { "source": "/(.*)", "destination": "/index.html" }
      ]
    },
    "api": {
      "root": "backend/",
      "entrypoint": "src/index.js"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "api" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
